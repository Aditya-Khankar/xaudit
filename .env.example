# xaudit environment configuration
#
# STEP 1: Copy this file to .env
#   cp .env.example .env
#
# STEP 2: Replace the placeholder below with your actual key
#   Get a free Gemini API key at: https://aistudio.google.com/apikey
#
# REQUIRED ONLY FOR: xaudit generate
# NOT REQUIRED FOR: xaudit analyze or xaudit demo

GEMINI_API_KEY=your_gemini_api_key_here
